# --- Prototipo local (Mongo + SMTP) ---
# Copia a .env y rellena valores secretos (nunca subas .env al repositorio).

PUERTO=3000

# Mongo local (migraciones requieren MONGODB_MOCK=false)
MONGODB_MOCK=false
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=notifications

# MailerSend SMTP (valores de ejemplo; usa tu usuario SMTP y token en .env real)
# MAIL_FROM debe ser un remitente verificado en MailerSend
SMTP_HOST=smtp.mailersend.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Campus <notificaciones@tudominioverificado.com>"

# Opcional: si no hay fila en Mongo, se usa este correo para el recordatorio
# DESTINATARIO_RECORDATORIO_MATRICULA=johannafavorite@gmail.com
# PLAZO_MATRICULA=15 de febrero de 2026
